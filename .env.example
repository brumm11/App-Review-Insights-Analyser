PULSE_DB_PATH=data/pulse.db
PULSE_PRODUCTS_PATH=data/products.yaml
PULSE_RAW_REVIEWS_DIR=data/raw
PULSE_SUMMARIES_DIR=data/summaries
PULSE_ARTIFACTS_DIR=data/artifacts
PULSE_EMBEDDING_CACHE_PATH=data/cache/embeddings.json
PULSE_DEFAULT_COUNTRY=in
PULSE_CLUSTER_LANGUAGE=en
PULSE_CLUSTER_MIN_CHARS=20
PULSE_EMBEDDING_PROVIDER=local_hash
PULSE_EMBEDDING_MODEL_LOCAL=BAAI/bge-small-en-v1.5
PULSE_EMBEDDING_MODEL_OPENAI=text-embedding-3-small
PULSE_EMBEDDING_DIMENSIONS=384
PULSE_UMAP_N_COMPONENTS=15
PULSE_HDBSCAN_MIN_CLUSTER_SIZE=8
PULSE_KEYPHRASE_TOP_N=8
PULSE_USE_KEYBERT=false
PULSE_LLM_PROVIDER=mock
PULSE_LLM_MODEL=mock-v1
PULSE_GROQ_API_KEY=
PULSE_LLM_TIMEOUT_SECONDS=30
PULSE_LLM_MAX_RETRIES=2
PULSE_LLM_TOKEN_CAP_PER_RUN=50000
PULSE_LLM_COST_CAP_USD_PER_RUN=20.0
PULSE_DOCS_MCP_TRANSPORT=fastmcp
PULSE_DOCS_MCP_URL=
PULSE_DOCS_MCP_COMMAND=
PULSE_GMAIL_MCP_TRANSPORT=fastmcp
PULSE_GMAIL_MCP_URL=
PULSE_GMAIL_MCP_COMMAND=
PULSE_EMAIL_PROVIDER=gmail
PULSE_RESEND_API_KEY=
PULSE_RESEND_FROM=onboarding@resend.dev
PULSE_MCP_MOCK_STATE_PATH=data/mcp/mock_state.json
PULSE_RUN_WEEKS_DEFAULT=10
PULSE_LOG_LEVEL=INFO
PULSE_CONFIRM_SEND=true
# When false, second publish for the same run skips email if a delivery id exists (Resend) or Gmail already has the run header.
PULSE_ALLOW_RESEND=true
